{
  "name": "mcbs-zugferd-converter",
  "version": "1.0.0",
  "description": "MCBS to ZUGFeRD E-Invoice Converter - AWS Lambda",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "validate:embedded:kosit": "bash scripts/validate-embedded-kosit.sh",
    "lint": "eslint ./src/**/*.ts",
    "lint:tests": "eslint ./test/**/*.ts",
    "lint:fix": "npm run lint -- --fix && npm run lint:tests -- --fix",
    "format:check": "prettier --check .",
    "format:write": "prettier --write --list-different .",
    "deploy:dev": "serverless deploy --stage dev",
    "deploy:staging": "serverless deploy --stage staging",
    "deploy:prod": "serverless deploy --stage production",
    "remove:dev": "serverless remove --stage dev",
    "logs": "serverless logs -f createEInvoice --tail",
    "invoke:local": "serverless invoke local -f createEInvoice --path events/test-event.json",
    "offline": "serverless offline",
    "test:e2e": "jest --config jest.e2e.config.ts --runInBand --verbose"
  },
  "keywords": [
    "zugferd",
    "e-invoice",
    "aws-lambda",
    "serverless",
    "mcbs",
    "factur-x"
  ],
  "author": "freenet DLS GmbH",
  "license": "PROPRIETARY",
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "3.962.0",
    "@aws-sdk/client-dynamodb": "3.980.0",
    "@aws-sdk/client-sns": "3.1000.0",
    "@aws-sdk/lib-dynamodb": "3.962.0",
    "@e-invoice-eu/core": "2.3.1",
    "fast-xml-parser": "4.5.4",
    "pino": "10.3.1",
    "zod": "4.3.6"
  },
  "overrides": {
    "@smithy/types": "4.12.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "3.995.0",
    "@aws-sdk/client-sqs": "3.995.0",
    "@eslint/eslintrc": "3.3.3",
    "@eslint/js": "9.39.2",
    "@types/aws-lambda": "8.10.160",
    "@types/jest": "29.5.12",
    "@types/node": "22.15.0",
    "eslint": "9.39.2",
    "eslint-formatter-unix": "9.0.1",
    "eslint-plugin-unused-imports": "4.3.0",
    "jest": "29.7.0",
    "pdf-lib": "1.17.1",
    "prettier": "3.7.4",
    "serverless": "4.30.0",
    "serverless-offline": "14.4.0",
    "testcontainers": "11.12.0",
    "ts-jest": "29.1.2",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0"
  },
  "engines": {
    "node": ">=22.x"
  }
}
