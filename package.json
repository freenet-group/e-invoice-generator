{
  "name": "mcbs-zugferd-converter",
  "version": "1.0.0",
  "description": "MCBS to ZUGFeRD E-Invoice Converter - AWS Lambda",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "deploy:dev": "serverless deploy --stage dev",
    "deploy:staging": "serverless deploy --stage staging",
    "deploy:prod": "serverless deploy --stage production",
    "remove:dev": "serverless remove --stage dev",
    "logs": "serverless logs -f createEInvoice --tail",
    "invoke:local": "serverless invoke local -f createEInvoice --path events/test-event.json",
    "offline": "serverless offline"
  },
  "keywords": [
    "zugferd",
    "e-invoice",
    "aws-lambda",
    "serverless",
    "mcbs",
    "factur-x"
  ],
  "author": "freenet DLS GmbH",
  "license": "PROPRIETARY",
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.540.0",
    "@aws-sdk/client-dynamodb": "^3.540.0",
    "@aws-sdk/client-s3": "^3.540.0",
    "@aws-sdk/client-sqs": "^3.540.0",
    "@aws-sdk/lib-dynamodb": "^3.540.0",
    "@e-invoice-eu/core": "^2.3.1",
    "fast-xml-parser": "^4.3.6"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.136",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "serverless": "^3.38.0",
    "serverless-offline": "^13.3.3",
    "serverless-plugin-typescript": "^2.1.5",
    "serverless-prune-plugin": "^2.0.2",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
